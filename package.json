{
  "name": "vapers-opti",
  "version": "1.6.0",
  "description": "Vapers Opti — Intelligent Windows Performance Optimization Suite",
  "author": "Vapers Opti",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 --timeout 60000 --interval 1000 && set NODE_ENV=development && npx electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:dir": "vite build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "app.vapersopti.optimizer",
    "productName": "Vapers Opti",
    "directories": { "output": "release", "buildResources": "assets" },
    "files": ["dist/**/*", "electron/**/*", "assets/**/*"],
    "extraResources": [{ "from": "scripts/", "to": "scripts/", "filter": ["**/*.ps1"] }],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }, { "target": "portable", "arch": ["x64"] }],
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "VapersOpti-Setup-${version}.${ext}"
    },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "createStartMenuShortcut": true, "shortcutName": "Vapers Opti" },
    "portable": { "artifactName": "VapersOpti-Portable-${version}.exe" },
    "publish": { "provider": "github", "owner": "vaperkill95", "repo": "vapers-opti" }
  }
}
